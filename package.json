{
  "name": "iconia",
  "version": "0.1.1",
  "description": "Fetch and generate React icon components from your Iconia collections",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "bin": {
    "iconia": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "bun build.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "14.0.3",
    "ora": "9.3.0",
    "picocolors": "1.1.1",
    "prettier": "3.8.1",
    "svgo": "4.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "bun-plugin-dts": "0.4.0",
    "typescript": "6.0.2"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "nodejs",
    "svg",
    "cli",
    "typescript",
    "icons",
    "bun"
  ],
  "license": "MIT",
  "author": "Wyesoftware",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wyesoftware/iconia.git"
  },
  "bugs": {
    "url": "https://github.com/Wyesoftware/iconia/issues"
  },
  "homepage": "https://github.com/Wyesoftware/iconia#readme"
}
