{
  "name": "iconia",
  "version": "0.0.2",
  "description": "Fetch and generate React icon components from your Iconia collections",
  "bin": {
    "iconia": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./*": {
      "types": "./*.d.ts",
      "default": "./*.js"
    }
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "commander": "14.0.3",
    "ora": "9.3.0",
    "picocolors": "1.1.1",
    "prettier": "3.8.1",
    "svgo": "4.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "tsup": "8.5.1",
    "typescript": "6.0.2"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "icons",
    "react",
    "svg",
    "cli"
  ],
  "license": "MIT"
}
